rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ─────────────────────────────────────────────────────────────

    // 이메일 로그인 사용자 (강사·관리자) — password provider 확인
    function isEmailUser() {
      return request.auth != null &&
        request.auth.token.firebase.sign_in_provider == 'password';
    }

    // 익명 로그인 사용자 (포털·등록폼)
    function isAnonymous() {
      return request.auth != null &&
        request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // 인증된 모든 사용자 (이메일 + 익명)
    // NOTE: Firebase Auth 비밀번호 동기화 문제로 이메일 Auth가 실패할 수 있음.
    // 읽기는 any auth로 허용하고, 앱 레벨에서 역할 기반 접근 제어를 처리함.
    function isAuthenticated() {
      return request.auth != null;
    }

    // 쓰기 권한 함수 — 이메일 로그인 = 전체 스태프
    function isAdmin()          { return isEmailUser(); }
    function isManagerOrAbove() { return isEmailUser(); }
    function isStaff()          { return isEmailUser(); }

    // ── appData 컬렉션별 규칙 ─────────────────────────────────────────────────

    // 학생 PII — 인증된 모든 사용자 읽기, 관리자 이상만 쓰기
    match /appData/rye-students {
      allow read:  if isAuthenticated();
      allow write: if isManagerOrAbove();
    }

    // 강사 정보 — 인증된 모든 사용자 읽기 (로그인 전 credential 확인 필요), 관리자 이상만 쓰기
    match /appData/rye-teachers {
      allow read:  if isAuthenticated();
      allow write: if isManagerOrAbove();
    }

    // 수납 기록 — 인증된 모든 사용자 읽기, 관리자/매니저만 쓰기
    match /appData/rye-payments {
      allow read:  if isAuthenticated();
      allow write: if isManagerOrAbove();
    }

    // 출석 기록 — 스태프 전체 쓰기, 익명(포털)은 배열 크기 유지·증가만 허용 (삭제 차단)
    match /appData/rye-attendance {
      allow read:  if isAuthenticated();
      allow write: if isEmailUser()
                   || (isAuthenticated()
                       && request.resource.data.keys().hasAll(['value', 'updatedAt'])
                       && request.resource.data.value.size() >= resource.data.value.size());
    }

    // 수강 등록 대기 — 인증된 모든 사용자 읽기·쓰기 (/register 폼)
    match /appData/rye-pending {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 회원 공지 — 인증된 모든 사용자 읽기·쓰기 (포털 읽음 처리)
    match /appData/rye-student-notices {
      allow read:  if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 기관(B2B) — 인증된 모든 사용자 읽기, 관리자 이상 쓰기
    match /appData/rye-institutions {
      allow read:  if isAuthenticated();
      allow write: if isManagerOrAbove();
    }

    // 카테고리 설정 — 인증된 모든 사용자 읽기, 관리자 이상 쓰기
    match /appData/rye-categories {
      allow read:  if isAuthenticated();
      allow write: if isManagerOrAbove();
    }

    // 수강료 프리셋 — 인증된 모든 사용자 읽기, 관리자 이상 쓰기
    match /appData/rye-fee-presets {
      allow read:  if isAuthenticated();
      allow write: if isManagerOrAbove();
    }

    // 스케줄 변경 — 인증된 모든 사용자 읽기, 이메일 사용자만 쓰기
    match /appData/rye-schedule-overrides {
      allow read:  if isAuthenticated();
      allow write: if isStaff();
    }

    // 활동 로그 — 인증된 모든 사용자 읽기, 이메일 사용자 쓰기
    match /appData/rye-activity {
      allow read:  if isAuthenticated();
      allow write: if isStaff();
    }

    // 휴지통 — 인증된 모든 사용자 읽기, admin만 쓰기
    match /appData/rye-trash {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // 공지사항 — 인증된 모든 사용자 읽기, 이메일 사용자 쓰기
    match /appData/rye-notices {
      allow read:  if isAuthenticated();
      allow write: if isStaff();
    }

    // 미청구·수납로그·AI리포트 — 인증된 모든 사용자 읽기, 관리자 쓰기
    match /appData/rye-unmatched-payments {
      allow read:  if isAuthenticated();
      allow write: if isManagerOrAbove();
    }

    match /appData/rye-payment-log {
      allow read:  if isAuthenticated();
      allow write: if isManagerOrAbove();
    }

    match /appData/rye-ai-reports {
      allow read:  if isAuthenticated();
      allow write: if isManagerOrAbove();
    }

    // 앱 설정 — 인증된 모든 사용자 읽기, 관리자 쓰기
    match /appData/rye-settings {
      allow read:  if isAuthenticated();
      allow write: if isManagerOrAbove();
    }

    // 상품 카탈로그 — 인증된 모든 사용자 읽기, 관리자 이상 쓰기
    match /appData/rye-shop-items {
      allow read:  if isAuthenticated();
      allow write: if isManagerOrAbove();
    }

    // 미지정 appData 문서 — 관리자 이상만 (신규 컬렉션 추가 시 기본 보호)
    match /appData/{document} {
      allow read, write: if isManagerOrAbove();
    }

    // 즉시 청구 (독립 컬렉션) — 생성은 스태프(강사 포함), 수정·삭제는 이메일 유저만
    match /rye-instant-charges/{docId} {
      allow read:   if isAuthenticated();
      allow create: if isEmailUser();
      allow update: if isEmailUser();
      allow delete: if isAdmin();
    }

    // 그 외 모든 경로 — 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
