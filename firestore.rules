rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ─────────────────────────────────────────────────────────────

    // 인증된 모든 사용자 (익명 포함) — 포털·등록폼 진입용
    function isAuthed() {
      return request.auth != null;
    }

    // 이메일 로그인 사용자 (강사·관리자) — password provider 확인
    // firebaseSignIn: {username}@ryek.app 형식으로 Firebase Auth 생성
    function isEmailUser() {
      return request.auth != null &&
        request.auth.token.firebase.sign_in_provider == 'password';
    }

    // ── appData 컬렉션 ────────────────────────────────────────────────────────

    // 기본 규칙: 읽기는 인증된 모든 사용자, 쓰기는 이메일 사용자만
    match /appData/{document} {
      allow read:  if isAuthed();
      allow write: if isEmailUser();
    }

    // 공개 수강 등록 폼 — 익명 사용자가 rye-pending에 신청서 제출
    match /appData/rye-pending {
      allow read, write: if isAuthed();
    }

    // 출석 레코드 — 포털 회원이 레슨노트에 댓글 작성 (rye-attendance 내 comments[])
    match /appData/rye-attendance {
      allow read, write: if isAuthed();
    }

    // 수강생 공지 — 포털 회원이 readBy[] 업데이트 (읽음 처리)
    match /appData/rye-student-notices {
      allow read, write: if isAuthed();
    }

    // ── 그 외 모든 컬렉션: 차단 ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
