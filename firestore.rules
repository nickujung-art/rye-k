rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ─────────────────────────────────────────────────────────────

    // 인증된 모든 사용자 (익명 포함) — 포털·등록폼 진입용
    function isAuthed() {
      return request.auth != null;
    }

    // 이메일 로그인 사용자 (강사·관리자) — password provider 확인
    // firebaseSignIn: {username}@ryek.app 형식으로 Firebase Auth 생성
    function isEmailUser() {
      return request.auth != null &&
        request.auth.token.firebase.sign_in_provider == 'password';
    }

    // ── appData 컬렉션 ────────────────────────────────────────────────────────

    // 기본 규칙: 읽기는 인증된 모든 사용자, 쓰기는 이메일 사용자만
    match /appData/{document} {
      allow read:  if isAuthed();
      allow write: if isEmailUser();
    }

    // 공개 수강 등록 폼 — 익명 사용자가 rye-pending에 신청서 제출
    match /appData/rye-pending {
      allow read, write: if isAuthed();
    }

    // 출석 레코드 — 포털 회원이 레슨노트에 댓글 작성 (rye-attendance 내 comments[])
    match /appData/rye-attendance {
      allow read, write: if isAuthed();
    }

    // 수강생 공지 — 포털 회원이 readBy[] 업데이트 (읽음 처리)
    match /appData/rye-student-notices {
      allow read, write: if isAuthed();
    }

    // 휴지통 — 운영자(강사·관리자)만 쓰기 (익명 포털은 접근 불가)
    match /appData/rye-trash {
      allow read: if isAuthed();
      allow write: if isEmailUser();
    }

    // 활동 로그 — 운영자(강사·관리자)만 쓰기 (익명 포털은 접근 불가)
    match /appData/rye-activity {
      allow read: if isAuthed();
      allow write: if isEmailUser();
    }

    // ── 보안 노트 (v14.3) ─────────────────────────────────────────────────────
    // rye-teachers: 익명 read 허용 (PublicPortal에서 강사 이름 lookup). v14.4에서
    //   student doc에 teacherName denormalize 후 emailUser-only로 잠글 예정.
    // rye-attendance: 익명 write 허용 (포털 학부모 댓글). v14.4에서 comments를
    //   서브컬렉션으로 분리하여 부모 doc은 emailUser-only로 잠글 예정.
    // rye-pending: 익명 write 필수 (/register 폼). 변경 없음.

    // ── 그 외 모든 컬렉션: 차단 ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
